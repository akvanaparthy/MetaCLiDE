{
  "name": "metaclide",
  "version": "0.1.0",
  "description": "Orchestrate any combination of AI coding agents as a collaborative peer team",
  "keywords": [
    "cli",
    "ai",
    "agents",
    "orchestration",
    "claude",
    "codex",
    "kimi"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "metaclide": "./bin/run.js"
  },
  "oclif": {
    "bin": "metaclide",
    "dirname": "metaclide",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "topicSeparator": " ",
    "plugins": [
      "@oclif/plugin-help"
    ]
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "dev": "npm run build && node bin/run.js",
    "start": "node bin/run.js",
    "test": "vitest run",
    "prepack": "npm run build && oclif manifest",
    "postpack": "shx rm -f oclif.manifest.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.0",
    "@anthropic-ai/sdk": "^0.78.0",
    "@inquirer/prompts": "^8.3.0",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@types/react": "^18.3.28",
    "execa": "^9",
    "ink": "^5.2.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "keytar": "^7",
    "open": "^11.0.0",
    "openai": "^4",
    "react": "^18.3.1",
    "simple-git": "^3",
    "yaml": "^2",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "shx": "^0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
